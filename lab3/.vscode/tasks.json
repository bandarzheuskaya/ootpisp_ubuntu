{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake -S \"${workspaceFolder}\" -B \"${workspaceFolder}/build\" -DCMAKE_PREFIX_PATH=/usr/lib/x86_64-linux-gnu/cmake/Qt5 -DCMAKE_BUILD_TYPE=Debug",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake --build \"${workspaceFolder}/build\"",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake Configure",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Run ShapeEditor",
            "type": "shell",
            "command": "./ShapeEditor",
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "dependsOn": "CMake Build",
            "problemMatcher": []
        }
    ]
}